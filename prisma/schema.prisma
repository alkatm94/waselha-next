generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id             Int      @id @default(autoincrement())
  customerName   String?
  phone          String?
  productUrl     String
  productName    String?
  country        String
  currency       String
  productPrice   Float
  weightKg       Float
  serviceTier    String
  estimatedTotal Float
  status         String   @default("new")
  createdAt      DateTime @default(now())
}

model QuotePreset {
  id          Int      @id @default(autoincrement())
  country     String
  currency    String
  fxToSar     Float
  shippingPerKg Float
  serviceFee  Float
  createdAt   DateTime @default(now())
}
